# FTP Doc Reader - Configuration Example
# Copy this file to .env and fill in your FTP server details.

# Required: FTP server hostname or IP address
FTP_HOST=ftp.example.com

# Optional: FTP server port (default: 21)
FTP_PORT=21

# Required: FTP login username
FTP_USERNAME=your_username

# Required: FTP login password
FTP_PASSWORD=your_password

# Optional: Protocol - FTP or FTPS (default: FTP)
FTP_PROTOCOL=FTP

# Optional: Local cache directory (default: .cache)
CACHE_DIR=.cache
